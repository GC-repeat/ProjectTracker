# ============================================================================
# EXAMPLE CONFIGURATION FILE
# 1. Rename this file to "password.env"
# 2. Setup the password below
# ============================================================================

# Password used to access the panel
PASSWORD=your_password

# ============================================================================
# Secret key used by express-session to sign session cookies.
# Change this value before deploying to production.
# Use a long random string (32+ characters recommended).
# Never share this value publicly.
# ============================================================================

SESSION_SECRET=put_a_long_random_string_here_min_32_chars